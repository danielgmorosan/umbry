# gossip-sdk (vendor/gossip submodule) references vite/client ambient types and imports
# @capacitor/core types, but doesn't declare either as its own dependency (they're only used
# by the submodule's native/Capacitor build target, which this workspace doesn't build yet).
# pnpm's default strict, per-package node_modules means it can't resolve them otherwise.
# Hoisting to the true workspace root lets Node/TypeScript's upward node_modules resolution
# find them without editing the (vendored, upstream-owned) submodule.
public-hoist-pattern[]=vite
public-hoist-pattern[]=@capacitor/core
