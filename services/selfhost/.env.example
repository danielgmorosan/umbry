# Copy to `.env` and fill in, or let the desktop app generate it for you
# (Settings -> Self-hosting -> Start local stack).
#
#   cp .env.example .env
#   docker compose up -d

# Address CLIENTS use to reach this box.
#   localhost      -> just this machine
#   192.168.1.42   -> teammates on your LAN (use your real LAN IP)
#   umbry.acme.com -> a server with DNS
# Calls break if this is wrong: LiveKit advertises it as the media address.
UMBRY_HOST=localhost

# LiveKit credentials. Generate a fresh pair — do NOT ship these values:
#   openssl rand -hex 16   (key)
#   openssl rand -hex 32   (secret)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Model the AI uses. Pulled on first use via Settings -> AI Engine.
#   qwen2.5:7b   ~4.7GB  good default, runs on CPU
#   qwen2.5:14b  ~9GB    sharper, wants a GPU or lots of RAM
#   llama3.2:3b  ~2GB    fastest, noticeably weaker recaps
AI_MODEL=qwen2.5:7b

# Origins allowed to call the relay from a browser. "*" is fine on a laptop;
# pin it to your app's URL on a shared server.
CORS_ORIGIN=*

# Require a proven identity for privileged relay actions. Leave on.
RELAY_REQUIRE_AUTH=1

# Host ports. Change only if something else already owns them.
RELAY_PORT=8788
LIVEKIT_PORT=7880
