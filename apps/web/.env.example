# Copy to .env. Frontend env only — NEVER put model API keys or secrets here.

# Message-transfer base URL. Default points at Gossip prod; override per-workspace for self-host.
VITE_GOSSIP_API_URL=https://api.usegossip.com

# OpenClaw gateway (the openclaw-bridge client targets this).
VITE_OPENCLAW_GATEWAY_URL=http://127.0.0.1:8787

# Base URL of the relay service (services/relay): group channels (WS), LiveKit tokens, and
# OpenClaw AI jobs. Leave unset for local dev (Vite proxies to localhost:8788) and for any
# same-origin deploy. Set to the relay's deployed origin (e.g. https://gossip-relay.fly.dev)
# when the web app and relay are deployed to separate hosts (Vercel + Fly.io).
VITE_RELAY_URL=

# Massa network (matches Gossip prod).
VITE_DEFAULT_MASSA_NETWORK=mainnet
