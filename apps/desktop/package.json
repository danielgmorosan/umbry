{
  "name": "@gossip/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Gossip desktop shell (Electron) — loads the web app in a hardened window.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "electron .",
    "dev": "tsc -p tsconfig.json && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^43.0.0",
    "typescript": "^5.7.2"
  }
}
